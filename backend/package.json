{
  "name": "pokemon-backend",
  "version": "0.0.1",
  "private": true,
  "description": "Pokemon Champions team analysis backend",
  "scripts": {
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "build": "nest build",
    "db:setup": "tsx scripts/setup-database.ts",
    "db:test": "tsx scripts/test-connection.ts",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "db:apply-views": "tsx scripts/apply-views.ts",
    "seed:types": "tsx scripts/seed-types.ts",
    "verify:types": "tsx scripts/verify-types.ts",
    "sync:abilities": "tsx scripts/sync-abilities.ts",
    "pc-overlay:abilities": "tsx scripts/pc-overlay-abilities.ts",
    "seed:abilities": "npm run sync:abilities && npm run pc-overlay:abilities",
    "verify:abilities": "tsx scripts/verify-abilities.ts",
    "sync:moves": "tsx scripts/sync-moves.ts",
    "pc-overlay:moves": "tsx scripts/pc-overlay-moves.ts",
    "seed:moves": "npm run sync:moves && npm run pc-overlay:moves",
    "verify:moves": "tsx scripts/verify-moves.ts",
    "sync:items": "tsx scripts/sync-items.ts",
    "pc-overlay:items": "tsx scripts/pc-overlay-items.ts",
    "seed:items": "npm run sync:items && npm run pc-overlay:items",
    "verify:items": "tsx scripts/verify-items.ts",
    "sync:pokemon": "tsx scripts/sync-pokemon.ts",
    "pc-overlay:pokemon": "tsx scripts/pc-overlay-pokemon.ts",
    "seed:pokemon": "npm run sync:pokemon && npm run pc-overlay:pokemon",
    "verify:pokemon": "tsx scripts/verify-pokemon.ts",
    "pc-overlay:mega-abilities": "tsx scripts/pc-overlay-mega-abilities.ts",
    "seed:mega-evolutions": "tsx scripts/seed-mega-evolutions.ts && npm run pc-overlay:mega-abilities",
    "verify:mega-evolutions": "tsx scripts/verify-mega-evolutions.ts",
    "seed:metadata": "tsx scripts/seed-metadata.ts",
    "verify:metadata": "tsx scripts/verify-metadata.ts",
    "mirror:sprites": "tsx scripts/mirror-sprites.ts",
    "seed:teams": "tsx scripts/seed-teams.ts",
    "verify:teams": "tsx scripts/verify-teams.ts",
    "verify:meta-threats": "tsx scripts/verify-meta-threats.ts"
  },
  "dependencies": {
    "@fastify/static": "^7.0.4",
    "@nestjs/common": "^10.4.5",
    "@nestjs/config": "^3.3.0",
    "@nestjs/core": "^10.4.5",
    "@nestjs/platform-fastify": "^10.4.5",
    "dotenv": "^16.4.5",
    "drizzle-orm": "^0.36.4",
    "fastify": "^5.2.1",
    "js-yaml": "^4.1.1",
    "mysql2": "^3.12.0",
    "nestjs-zod": "^4.2.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.0.0",
    "@nestjs/schematics": "^10.0.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.17.0",
    "drizzle-kit": "^0.28.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
